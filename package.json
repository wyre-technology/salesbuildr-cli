{
  "name": "@wyre-technology/salesbuildr-cli",
  "version": "1.0.0",
  "description": "Command-line interface for SalesBuildr - quotes, products, clients, and sales pipeline management",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "salesbuildr": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wyre-technology/salesbuildr-cli.git"
  },
  "keywords": [
    "salesbuildr",
    "cli",
    "quoting",
    "sales",
    "msp",
    "crm"
  ],
  "author": "Wyre Technology",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/wyre-technology/salesbuildr-cli/issues"
  },
  "homepage": "https://github.com/wyre-technology/salesbuildr-cli#readme",
  "dependencies": {
    "@wyre-technology/node-salesbuildr": "file:../../node-salesbuildr",
    "commander": "^12.0.0",
    "cli-table3": "^0.6.5",
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
